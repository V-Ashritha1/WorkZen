# Backend environment variables.
# Locally, application.properties already has safe defaults for all of
# these, so you don't need this file to run on your machine.
# On Render, set each of these in the service's Environment tab.

# MySQL connection (use your Render MySQL / PlanetScale / Railway connection string)
DB_URL=jdbc:mysql://<host>:3306/<database>
DB_USERNAME=<username>
DB_PASSWORD=<password>

# Must be a long, random string in production — generate one with:
# openssl rand -base64 32
JWT_SECRET=<a-long-random-base64-secret>

# Your deployed frontend's URL (Vercel). Comma-separate multiple origins.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Render sets this automatically — you don't need to set it yourself.
PORT=8080
